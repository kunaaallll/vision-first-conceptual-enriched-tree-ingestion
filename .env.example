# Copy this file to .env and fill in your values.

# Required
OPENAI_API_KEY=sk-...

# Database — change host/port/user/pass/dbname as needed
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/visionrag

# Models (defaults are good for most use cases)
VISION_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-large
LLM_MODEL=gpt-4o-mini
SUMMARY_MODEL=gpt-4o-mini

# Concurrency — lower this if you hit OpenAI rate limits
VISION_CONCURRENCY=5

# Storage paths (inside the container)
UPLOAD_DIR=uploads
VISION_CACHE_DIR=.vision_cache

# Enrichment
ENABLE_CONCEPT_SPLIT=true
